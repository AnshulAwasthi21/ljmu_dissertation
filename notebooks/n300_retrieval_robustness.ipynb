    "## 2 · Validity-gate + comparison helpers (with an inline self-test)\n",
    "\n",
    "These are the only new functions. The self-test cell runs them on toy data — including a deliberately corrupted chunk — and must print `SELF-TEST PASSED` before we trust the real gate."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "1104c45c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Helpers defined.\n"
     ]
    }
   ],
   "source": [
    "def sha256_chunks(df, id_col=\"chunk_id\", text_col=\"text\") -> str:\n",
    "    \"\"\"Content hash of a chunk set: sha256 over sorted (chunk_id, text) pairs.\"\"\"\n",
    "    pairs = sorted((str(c), str(t)) for c, t in zip(df[id_col], df[text_col]))\n",
    "    blob = \"\\n\".join(f\"{c}\\t{t}\" for c, t in pairs)\n",
    "    return hashlib.sha256(blob.encode(\"utf-8\")).hexdigest()\n",
    "\n",
    "def verify_prefix_reproduction(n100_chunks, n300_chunks, id_col=\"chunk_id\", text_col=\"text\") -> dict:\n",
    "    \"\"\"Prove the first-100 corpus reproduced byte-identically inside the n=300 build.\n",
    "    Raises AssertionError on any drift — this is the validity gate.\"\"\"\n",
    "    ids_100, ids_300 = set(n100_chunks[id_col]), set(n300_chunks[id_col])\n",
    "    missing = sorted(ids_100 - ids_300)\n",
    "    assert not missing, (f\"{len(missing)} n=100 chunk_id(s) absent at n=300 -> PREFIX BROKEN. \"\n",
    "                         f\"First few: {missing[:5]}\")\n",
    "    a = n100_chunks[[id_col, text_col]].rename(columns={text_col: \"_t100\"})\n",
    "    b = n300_chunks[[id_col, text_col]].rename(columns={text_col: \"_t300\"})\n",
    "    m = a.merge(b, on=id_col, how=\"inner\", validate=\"one_to_one\")\n",
    "    mismatch = m.loc[m[\"_t100\"] != m[\"_t300\"], id_col].tolist()\n",
    "    assert not mismatch, (f\"{len(mismatch)} shared chunk_id(s) differ in text at n=300 -> PREFIX BROKEN. \"\n",
    "                          f\"First few: {mismatch[:5]}\")\n",
    "    return {\"n100_chunks\": len(ids_100), \"n300_chunks\": len(ids_300),\n",
    "            \"shared_ids_checked\": int(len(m)), \"text_mismatches\": 0,\n",
    "            \"missing_n100_ids\": 0, \"prefix_reproduced\": True}\n",
    "\n",
    "def gold_chunks_valid(golden_df, n300_chunks, n100_chunks, id_col=\"chunk_id\", text_col=\"text\") -> dict:\n",
    "    \"\"\"Every gold chunk_id must exist at n=300 with text identical to the n=100 control.\"\"\"\n",
    "    gold_ids = sorted({c for ids in golden_df[\"relevant_chunk_ids\"] for c in ids})\n",
    "    t300 = n300_chunks.set_index(id_col)[text_col].to_dict()\n",
    "    t100 = n100_chunks.set_index(id_col)[text_col].to_dict()\n",
    "    absent = [c for c in gold_ids if c not in t300]\n",
    "    assert not absent, f\"{len(absent)} gold chunk(s) absent at n=300: {absent[:5]}\"\n",
    "    drift = [c for c in gold_ids if t300[c] != t100.get(c)]\n",
    "    assert not drift, f\"{len(drift)} gold chunk(s) changed text at n=300: {drift[:5]}\"\n",
    "    return {\"n_gold_chunks\": len(gold_ids), \"all_present\": True, \"all_text_identical\": True}\n",
    "\n",
    "def overall_metrics(per_query_df, k_values=K_VALUES) -> dict:\n",
    "    \"\"\"Mean of each metric over all queries (pandas-3 safe: no groupby.apply).\"\"\"\n",
    "    cols = [f\"{m}@{k}\" for k in k_values for m in (\"precision\", \"recall\", \"mrr\")]\n",
    "    cols = [c for c in cols if c in per_query_df.columns]\n",
    "    return {c: round(float(per_query_df[c].mean()), 4) for c in cols}\n",
    "\n",
    "def by_source_metrics(per_query_df, k_values=K_VALUES) -> dict:\n",
    "    cols = [f\"{m}@{k}\" for k in k_values for m in (\"precision\", \"recall\", \"mrr\")]\n",
    "    cols = [c for c in cols if c in per_query_df.columns]\n",
    "    g = per_query_df.groupby(\"source\")[cols].mean().round(4)\n",
    "    return {src: row.to_dict() for src, row in g.iterrows()}\n",
    "\n",
    "def evaluate_claims(overall: dict) -> list:\n",
    "    \"\"\"Claim verdicts computed straight from the n=300 numbers (no hand-typed values).\"\"\"\n",
    "    b, d, h = overall[\"bm25\"], overall[\"dense\"], overall[\"hybrid\"]\n",
    "    checks = [\n",
    "        (\"BM25 > dense (MRR@10)\",                 b[\"mrr@10\"] >  d[\"mrr@10\"]),\n",
    "        (\"BM25 > dense (Recall@5)\",               b[\"recall@5\"] > d[\"recall@5\"]),\n",
    "        (\"Hybrid best or tied (MRR@10)\",          h[\"mrr@10\"] >= max(b[\"mrr@10\"], d[\"mrr@10\"])),\n",
    "        (\"Recall@5 order: hybrid >= BM25 >= dense\", h[\"recall@5\"] >= b[\"recall@5\"] >= d[\"recall@5\"]),\n",
    "    ]\n",
    "    return [(name, \"HOLDS\" if ok else \"DIFFERS\") for name, ok in checks]\n",
    "print(\"Helpers defined.\")"
   ]
  },
